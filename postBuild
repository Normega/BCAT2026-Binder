#!/bin/bash
set -e

REPO=Normega/BCAT2026-Binder
BASE=https://raw.githubusercontent.com/${REPO}

mkdir -p Results/Models/TestRDS Results/Models/Study3 Results/Models/MissBaseline

# Download all model RDS files in parallel
# TestRDS + Study3 from commit d0d86a2; MissBaseline from commit 40b4b6e
declare -A FILES
FILES["Results/Models/TestRDS/brms_arousal_group_bs.rds"]=d0d86a2
FILES["Results/Models/TestRDS/brms_arousal_nodirect_group.rds"]=d0d86a2
FILES["Results/Models/TestRDS/brms_mediator_group.rds"]=d0d86a2
FILES["Results/Models/TestRDS/brms_outcome_arousal_group.rds"]=d0d86a2
FILES["Results/Models/TestRDS/brms_outcome_confidence_group.rds"]=d0d86a2
FILES["Results/Models/Study3/brms_m0.rds"]=d0d86a2
FILES["Results/Models/Study3/brms_m1.rds"]=d0d86a2
FILES["Results/Models/Study3/brms_maia_moderation.rds"]=d0d86a2
FILES["Results/Models/MissBaseline/brms_miss_m0_study1a.rds"]=40b4b6e
FILES["Results/Models/MissBaseline/brms_miss_m1_study1a.rds"]=40b4b6e
FILES["Results/Models/MissBaseline/brms_miss_m0_study2.rds"]=40b4b6e
FILES["Results/Models/MissBaseline/brms_miss_m1_study2.rds"]=40b4b6e
FILES["Results/Models/MissBaseline/brms_miss_m0_study4.rds"]=40b4b6e
FILES["Results/Models/MissBaseline/brms_miss_m1_study4.rds"]=40b4b6e
FILES["Results/Models/MissBaseline/brms_miss_m0_study5.rds"]=40b4b6e
FILES["Results/Models/MissBaseline/brms_miss_m1_study5.rds"]=40b4b6e

for f in "${!FILES[@]}"; do
  commit="${FILES[$f]}"
  echo "Downloading ${f}..."
  wget -q "${BASE}/${commit}/${f}" -O "${f}" &
done

wait
echo "All model objects downloaded."
