#!/bin/bash
set -e

# Download pre-computed brms model objects from the pinned commit where they
# were originally stored. This keeps the repo clone small for Binder while
# still making models available without recomputation.
REPO=Normega/BCAT2026-Binder
BASE=https://raw.githubusercontent.com/${REPO}

mkdir -p Results/Models/TestRDS Results/Models/Study3 Results/Models/MissBaseline

# TestRDS + Study3 models (committed at d0d86a2)
for f in \
  Results/Models/TestRDS/brms_arousal_group_bs.rds \
  Results/Models/TestRDS/brms_arousal_nodirect_group.rds \
  Results/Models/TestRDS/brms_mediator_group.rds \
  Results/Models/TestRDS/brms_outcome_arousal_group.rds \
  Results/Models/TestRDS/brms_outcome_confidence_group.rds \
  Results/Models/Study3/brms_m0.rds \
  Results/Models/Study3/brms_m1.rds \
  Results/Models/Study3/brms_maia_moderation.rds
do
  echo "Downloading ${f}..."
  wget -q "${BASE}/d0d86a2/${f}" -O "${f}"
done

# MissBaseline models (committed at 40b4b6e)
for f in \
  Results/Models/MissBaseline/brms_miss_m0_study1a.rds \
  Results/Models/MissBaseline/brms_miss_m1_study1a.rds \
  Results/Models/MissBaseline/brms_miss_m0_study2.rds \
  Results/Models/MissBaseline/brms_miss_m1_study2.rds \
  Results/Models/MissBaseline/brms_miss_m0_study4.rds \
  Results/Models/MissBaseline/brms_miss_m1_study4.rds \
  Results/Models/MissBaseline/brms_miss_m0_study5.rds \
  Results/Models/MissBaseline/brms_miss_m1_study5.rds
do
  echo "Downloading ${f}..."
  wget -q "${BASE}/40b4b6e/${f}" -O "${f}"
done

echo "All model objects downloaded."
